#!/usr/bin/env python3
import csv, sys, os
from datetime import date
from pathlib import Path
from collections import defaultdict

CSV = Path.home() / "money" / "money.csv"

def add(amount, tag):
    try:
        amt = float(amount)
    except ValueError:
        sys.exit(f"error: '{amount}' is not a number")
    CSV.parent.mkdir(exist_ok=True)
    with open(CSV, "a", newline="") as f:
        csv.writer(f).writerow([date.today(), amt, tag])
    print(f"+ {amt:.2f} BAM  {tag}")

def sync():
    os.chdir(CSV.parent)
    os.system(f'git add money.csv && git commit -m "{date.today()}" && git push')

def list_entries(n=10):
    if not CSV.exists(): return
    with open(CSV) as f:
        rows = list(csv.reader(f))
    for d, amt, tag in reversed(rows[-int(n):]):
        print(f"{d}  {float(amt):>10.2f} BAM  {tag}")

def sum_entries(prefix=None, n=12):
    if not CSV.exists(): return
    data = defaultdict(lambda: defaultdict(float))  # month -> tag -> amount
    with open(CSV) as f:
        for d, amt, tag in csv.reader(f):
            if prefix and not tag.startswith(prefix): continue
            month = d[:7]
            key = tag if prefix else tag.split("-")[0]
            data[month][key] += float(amt)
    for month in sorted(data, reverse=True)[:int(n)]:
        print(month)
        for tag, total in sorted(data[month].items(), key=lambda x: -x[1]):
            print(f"  {tag:<20} {total:>10.2f} BAM")
        print(f"  {'total':<20} {sum(data[month].values()):>10.2f} BAM")
        print()

def completions():
    if not CSV.exists(): return
    with open(CSV) as f:
        tags = {row[2] for row in csv.reader(f) if row}
    print("\n".join(sorted(tags)))

match sys.argv[1:]:
    case ["add", amount, tag]:          add(amount, tag)
    case ["list"]:                      list_entries()
    case ["list", n]:                   list_entries(n)
    case ["sum"]:                       sum_entries()
    case ["sum", "-n", n]:              sum_entries(n=n)
    case ["sum", prefix]:               sum_entries(prefix=prefix)
    case ["sum", prefix, "-n", n]:      sum_entries(prefix=prefix, n=n)
    case ["sync"]:                      sync()
    case ["--completions"]:             completions()
    case _: print("usage: money add <amount> <tag> | list [N] | sum [prefix] [-n N] | sync")
